# Server-only Product Analysis LLM configuration. Never expose these values to the browser.
# If all three custom LLM_* values are set, Atlas uses that OpenAI-compatible provider.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
# Recommended: comma-separated allowlist, e.g. api.openai.com,openrouter.ai
LLM_ALLOWED_HOSTS=

# OpenAI fallback used when LLM_BASE_URL + LLM_API_KEY + LLM_MODEL are not all set.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Required for Product Analysis public URL fetching and custom LLM endpoint DNS checks.
# Cloudflare DoH JSON endpoint. Atlas sends GET requests like:
#   ${ATLAS_DNS_RESOLVER}?name=example.com&type=A
#   ${ATLAS_DNS_RESOLVER}?name=example.com&type=AAAA
ATLAS_DNS_RESOLVER=https://cloudflare-dns.com/dns-query
