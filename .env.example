# Server-only Product Analysis LLM configuration. Never expose these values to the browser.
# If all three custom LLM_* values are set, Atlas uses that OpenAI-compatible provider.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
# Recommended: comma-separated allowlist, e.g. api.openai.com,openrouter.ai
LLM_ALLOWED_HOSTS=

# OpenAI fallback used when LLM_BASE_URL + LLM_API_KEY + LLM_MODEL are not all set.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Required for Product Analysis public URL fetching and custom LLM endpoint DNS checks.
# Cloudflare DoH JSON endpoint. Atlas sends GET requests like:
#   ${ATLAS_DNS_RESOLVER}?name=example.com&type=A
#   ${ATLAS_DNS_RESOLVER}?name=example.com&type=AAAA
ATLAS_DNS_RESOLVER=https://cloudflare-dns.com/dns-query

# Official publishing connections (server-only). WordPress defaults to draft.
# Atlas application OAuth configuration. User tokens are encrypted per Workspace in D1.
# Generate a 32-byte random key and store it as base64. Never rotate it without re-encrypting stored connections.
CONNECTION_ENCRYPTION_KEY=
ATLAS_PUBLIC_URL=https://atlas.lumeword.com
X_CLIENT_ID=
X_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
WORDPRESS_PUBLISH_STATUS=draft
REDDIT_USER_AGENT=Atlas/1.0

# Atlas account sign-in. All secrets are server-only.
ATLAS_APP_URL=https://atlas.lumeword.com
RESEND_API_KEY=
AUTH_EMAIL_FROM=Atlas <login@auth.lumeword.com>
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Use the same Google OAuth client for Search Console, with this exact redirect URI registered:
# https://atlas.lumeword.com/api/connections/callback?provider=google_search_console
# Atlas requests only webmasters.readonly and requires an owner/full-permission HTTPS property.

# Measurement. Atlas first-party tracking remains available without GA4/PostHog.
ATLAS_TRACKING_ENABLED=1
GA4_PROPERTY_ID=
POSTHOG_PROJECT_KEY=
# Optional hard deadlines covering response headers and the complete response body.
ATLAS_DIRECT_FETCH_TIMEOUT_MS=8000
ATLAS_READER_TIMEOUT_MS=15000

# Server-only key used by the external scheduler that invokes the Atlas Agent Runtime.
# Use at least 32 random characters. Never expose this value to the browser.
ATLAS_RUNTIME_SECRET=
