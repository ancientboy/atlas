# Server-only Product Analysis LLM configuration. Never expose these values to the browser.
# If all three custom LLM_* values are set, Atlas uses that OpenAI-compatible provider.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
# Recommended: comma-separated allowlist, e.g. api.openai.com,openrouter.ai
LLM_ALLOWED_HOSTS=

# OpenAI fallback used when LLM_BASE_URL + LLM_API_KEY + LLM_MODEL are not all set.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Required for Product Analysis public URL fetching and custom LLM endpoint DNS checks.
# Cloudflare DoH JSON endpoint. Atlas sends GET requests like:
#   ${ATLAS_DNS_RESOLVER}?name=example.com&type=A
#   ${ATLAS_DNS_RESOLVER}?name=example.com&type=AAAA
ATLAS_DNS_RESOLVER=https://cloudflare-dns.com/dns-query

# Official publishing connections (server-only). WordPress defaults to draft.
WORDPRESS_BASE_URL=
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=
WORDPRESS_PUBLISH_STATUS=draft
X_ACCESS_TOKEN=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=
REDDIT_ACCESS_TOKEN=
REDDIT_SUBREDDIT=
REDDIT_USER_AGENT=Atlas/1.0

# Measurement. Atlas first-party tracking remains available without GA4/PostHog.
ATLAS_TRACKING_ENABLED=1
GA4_PROPERTY_ID=
POSTHOG_PROJECT_KEY=
# Optional hard deadlines covering response headers and the complete response body.
ATLAS_DIRECT_FETCH_TIMEOUT_MS=8000
ATLAS_READER_TIMEOUT_MS=15000
