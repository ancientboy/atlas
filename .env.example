# Server-only LLM configuration. Never expose these values to the browser.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional fallback name read by the Atlas API route.
LLM_API_KEY=

# Required for Product Analysis public URL fetching.
# Cloudflare DoH JSON endpoint. Atlas sends GET requests like:
#   ${ATLAS_DNS_RESOLVER}?name=example.com&type=A
#   ${ATLAS_DNS_RESOLVER}?name=example.com&type=AAAA
# with Accept: application/dns-json and expects Cloudflare DNS JSON
# responses containing Answer[] records with type 1 (A) or 28 (AAAA).
ATLAS_DNS_RESOLVER=https://cloudflare-dns.com/dns-query
